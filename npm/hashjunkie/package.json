{
  "name": "@perw/hashjunkie",
  "version": "0.2.0",
  "description": "Multi-hash streaming library for Node.js and Bun — all hashes in one pass",
  "main": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./index.ts"
    }
  },
  "files": [
    "README.md",
    "index.ts",
    "types.ts",
    "loader.ts",
    "wasm.ts",
    "wasm_blob.ts",
    "hashjunkie_wasm.js",
    "hashjunkie_wasm.d.ts",
    "globals.d.ts",
    "tsconfig.json",
    "*.node"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["hash", "checksum", "streaming", "blake3", "sha256", "xxhash", "wasm", "napi"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Tuxie/HashJunkie.git",
    "directory": "npm/hashjunkie"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:wasm": "../../scripts/build-wasm.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "bun-types": "^1.3.12"
  },
  "optionalDependencies": {
    "@perw/hashjunkie-linux-x64-gnu": "workspace:*",
    "@perw/hashjunkie-linux-arm64-gnu": "workspace:*",
    "@perw/hashjunkie-darwin-x64": "workspace:*",
    "@perw/hashjunkie-darwin-arm64": "workspace:*",
    "@perw/hashjunkie-win32-x64-msvc": "workspace:*"
  },
  "license": "MIT"
}
